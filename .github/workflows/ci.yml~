name: Websource CI/CD

on:
  push:
    branches: [ main ]

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Source Code
        uses: actions/checkout@v4

      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build and Push Docker Image
        uses: docker/build-push-action@v5
        with:
          context: ./Websource
          push: true
          tags: ${{ secrets.DOCKER_USERNAME }}/hybrid-dr-web:${{ github.sha }}

      - name: Checkout GitOps Repo
        uses: actions/checkout@v4
        with:
          repository: ${{ github.repository_owner }}/gitops-repo
          token: ${{ secrets.PAT_TOKEN }}
          path: gitops-repo

      - name: Update Kubernetes Manifests
        run: |
          IMAGE_TAG=${{ github.sha }}
          DOCKER_USER=${{ secrets.DOCKER_USERNAME }}
          
          # AWS values.yaml 업데이트
          sed -i "s|image:.*|image: \"$DOCKER_USER/hybrid-dr-web:$IMAGE_TAG\"|g" gitops-repo/my_web_chart/aws/values.yaml
          
          # On-Premise values.yaml 업데이트
          sed -i "s|image:.*|image: \"$DOCKER_USER/hybrid-dr-web:$IMAGE_TAG\"|g" gitops-repo/my_web_chart/OnPremise/values.yaml

      - name: Commit and Push Changes
        run: |
          cd gitops-repo
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add .
          git commit -m "Update image tag to ${{ github.sha }} [skip ci]"
          git push
